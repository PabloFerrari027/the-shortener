
generator client {
  provider = "prisma-client"
  output   = "../../../../../../.prisma/pg"
}

datasource db {
  provider = "postgresql"
}

model ShortUrl {
  id         String    @id
  hash       String    @unique
  url        String
  clickCount Int       @map("click_count")
  removedAt  DateTime? @map("removed_at")
  createdAt  DateTime  @map("created_at")
  updatedAt  DateTime  @map("updated_at") @updatedAt

  @@map("short_url")
}